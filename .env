# 服务配置
APP_NAME=车载视觉感知与人机交互系统
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库
# Windows 身份验证连接本机 SQL Server Express
DATABASE_URL=mssql+pyodbc://@.\SQLEXPRESS/VehicleVisionDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
DATABASE_ECHO=false

# 演示登录账号
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123

# LLM API (OpenAI 兼容接口，留空则使用模板告警)
# 推荐: LLM_PROVIDER=qwen 并填入通义千问 API Key
LLM_PROVIDER=qwen
LLM_API_KEY=sk-ws-H.EMIXXHL.MrsH.MEYCIQDh72RtvFy1ToXIf90iktLxKTumZ9J05DFioXAcPbTSbwIhAMHx0Mjjd0eAZ40Gtjn5Wc0yqtyzngXXoLhYGEvpeKNs
LLM_API_BASE=
LLM_MODEL=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=800

# ── 告警智能体（Part 4）────────────────────────────────────────
# ALERT_GESTURE_COOLDOWN_SECONDS=1800
# ALERT_COOLDOWN_SECONDS=60

# Webhook（答辩演示第二渠道）
# WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# ALERT_WEBHOOK_ENABLED=true

# 邮件（答辩演示第二渠道）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@qq.com
# SMTP_PASSWORD=your_smtp_auth_code
# ALERT_EMAIL_TO=receiver@example.com
# ALERT_EMAIL_ENABLED=true

ALERT_EMAIL_ENABLED=false
ALERT_WEBHOOK_ENABLED=false

# 数据集路径 (相对于项目根目录的上级 database 目录)
CCPD_DATA_PATH=../CCPD-master
CTPGR_DATA_PATH=../ctpgr-pytorch-master
HAGRID_DATA_PATH=../hagrid-master

# AES 加密密钥 (32字节 hex)
AES_KEY=0123456789abcdef0123456789abcdef
