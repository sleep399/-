# 服务配置
APP_NAME=车载视觉感知与人机交互系统
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 数据库
# Windows 身份验证连接本机 SQL Server Express
DATABASE_URL=mssql+pyodbc://@.\SQLEXPRESS/VehicleVisionDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
DATABASE_ECHO=false


# 邮件通知 (可选)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Webhook 通知 (企业微信/钉钉/飞书机器人)
WEBHOOK_URL=

# 数据集路径 (相对于项目根目录的上级 database 目录)
CCPD_DATA_PATH=../CCPD-master
CTPGR_DATA_PATH=../ctpgr-pytorch-master
HAGRID_DATA_PATH=../hagrid-master

# AES 加密密钥 (32字节 hex)
AES_KEY=0123456789abcdef0123456789abcdef
# ──────────────────────────────────────────────
# LLM API 配置（告警智能体调用预训练大模型，无需自己训练）
# ──────────────────────────────────────────────
# 1. 选择厂商（openai | qwen | deepseek | zhipu | custom）
LLM_PROVIDER=qwen

# 2. 填入对应平台的 API Key（必填，否则告警摘要使用内置模板）
#    通义千问: https://dashscope.console.aliyun.com/
#    DeepSeek: https://platform.deepseek.com/
#    智谱 GLM: https://open.bigmodel.cn/
#    OpenAI:   https://platform.openai.com/
LLM_API_KEY=

# 3. 以下留空则自动按 LLM_PROVIDER 选择；custom 时需手动填写
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo
LLM_API_BASE=
LLM_MODEL=

# 4. 可选调优
LLM_TIMEOUT=30
LLM_MAX_TOKENS=800

# ── 各厂商快速配置示例（取消注释对应块即可）──
#
# 【通义千问 - 推荐国内使用】
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-你的dashscope密钥
#
# 【DeepSeek - 性价比高】
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-你的deepseek密钥
#
# 【OpenAI - 需可访问国际网络】
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-你的openai密钥
# LLM_MODEL=gpt-3.5-turbo
